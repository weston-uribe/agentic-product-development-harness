# Required for live planning and implementation runs
LINEAR_API_KEY=
CURSOR_API_KEY=

# Required for handoff runs (Milestone 4+) and merge runs (Milestone 6+)
# Used for GitHub PR metadata, checks, comment inspection, and squash merge
GITHUB_TOKEN=

# --- Vercel webhook bridge only (Milestone 8) — not used by local harness CLI ---
# LINEAR_WEBHOOK_SECRET=
# GITHUB_DISPATCH_TOKEN=          # Fine-grained: Contents: write on harness repo; Classic: repo scope
# GITHUB_DISPATCH_REPOSITORY=     # optional; default weston-uribe/agentic-product-development-harness
# GITHUB_DISPATCH_EVENT_TYPE=     # optional; default linear_issue_status_changed
# LINEAR_WEBHOOK_TIMESTAMP_TOLERANCE_MS=  # optional; default 60000
# HARNESS_TEAM_KEY=               # optional; e.g. WES

# --- GitHub Actions only (Milestone 8) — configure in repo Settings → Secrets, not .env ---
# HARNESS_GITHUB_TOKEN=           # PAT with access to harness target repos; workflow maps to GITHUB_TOKEN
