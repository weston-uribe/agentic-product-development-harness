{
  "name": "agentic-product-development-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Repo-agnostic Cursor SDK orchestration harness (Milestone 8: Linear watcher)",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:webhook": "vitest run tests/webhook",
    "harness:doctor": "tsx src/index.ts doctor",
    "harness:run": "tsx src/index.ts run",
    "harness:inspect": "tsx src/index.ts inspect",
    "harness:validate-issue": "tsx src/index.ts validate-issue",
    "generate:config-schema": "tsx scripts/generate-config-schema.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@linear/sdk": "^40.0.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "zod-to-json-schema": "^3.24.5"
  }
}
