{
  "name": "agentic-product-development-harness",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Cursor-first Linear/GitHub/GitHub Actions orchestration harness (SDK runners planning–merge, event-driven auto-run).",
  "scripts": {
    "build": "tsc && npm run build:gui",
    "build:gui": "next build apps/gui",
    "test": "vitest run",
    "test:webhook": "vitest run tests/webhook",
    "harness:gui": "tsx src/gui/start-gui.ts",
    "harness:configure": "tsx src/gui/start-gui.ts --route /settings/configure",
    "harness:configure:stable": "tsx src/gui/start-configure-stable.ts",
    "harness:doctor": "tsx src/index.ts doctor",
    "harness:diagnose:vercel-bridge": "tsx src/index.ts diagnose-vercel-bridge",
    "harness:run": "tsx src/index.ts run",
    "harness:inspect": "tsx src/index.ts inspect",
    "harness:validate-issue": "tsx src/index.ts validate-issue",
    "harness:resolve-route": "tsx src/index.ts resolve-route",
    "harness:sync-production": "tsx src/index.ts sync-production",
    "harness:redact-output": "tsx src/index.ts redact-output",
    "harness:operator:init": "tsx src/index.ts operator init",
    "generate:config-schema": "tsx scripts/generate-config-schema.ts",
    "package:p-dev:prepare": "tsx scripts/prepare-p-dev-package.ts",
    "package:p-dev:pack": "npm run package:p-dev:prepare && sh -c 'cd packages/p-dev && npm pack --pack-destination .'",
    "package:p-dev:inspect": "sh -c 'cd packages/p-dev && npm pack --dry-run --json'",
    "test:workflow:browser": "playwright test --config scripts/workflow-browser-matrix.config.ts",
    "test:configure:browser": "playwright test --config scripts/configure-browser-matrix.config.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@linear/sdk": "^88.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/node": "^9.47.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "posthog-node": "^5.26.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.7.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "tweetsodium": "^0.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "zod-to-json-schema": "^3.24.5"
  }
}
